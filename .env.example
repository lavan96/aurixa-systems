# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ── Aurixa Systems storefront backend (Supabase project moeyytuduycrvvncdtme) ──
# The browser talks to THIS site's own backend. billing.ts + leads.ts resolve
# the functions base in this order: VITE_STOREFRONT_API_URL, else
# {VITE_SUPABASE_URL}/functions/v1, else the known production project.
VITE_SUPABASE_URL="https://moeyytuduycrvvncdtme.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-publishable-key"
# Optional explicit override of the storefront functions base URL:
# VITE_STOREFRONT_API_URL="https://moeyytuduycrvvncdtme.supabase.co/functions/v1"

# VITE_MISSION_CONTROL_URL: Mission Control origin. The storefront backend
# forwards checkout/handoff/identity/session here (MC stays the billing engine +
# Stripe); leads.ts also mirrors leads to MC's operator console. The storefront
# edge functions themselves default MISSION_CONTROL_URL to this same origin.
VITE_MISSION_CONTROL_URL="https://mission-control.aurixasystems.com.au"
